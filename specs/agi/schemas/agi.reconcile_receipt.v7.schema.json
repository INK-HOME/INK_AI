{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agi.reconcile_receipt.v7.schema.json",
  "title": "AGI ReconcileReceipt v7",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reconcile_receipt_id",
    "corridor_id",
    "binds_envelope",
    "binds_decision",
    "binds_certification",
    "entered_indoubt_at",
    "indoubt_trigger",
    "reconciliation_started_at",
    "reconciliation_actor",
    "reconciliation_mode",
    "resolution",
    "closure",
    "seal"
  ],
  "properties": {
    "schema_version": {
      "const": "agi.reconcile_receipt.v7"
    },
    "reconcile_receipt_id": {
      "type": "string"
    },
    "corridor_id": {
      "type": "string"
    },
    "law_epoch_ref": {
      "type": "string"
    },
    "binds_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "envelope_id",
        "envelope_digest"
      ],
      "properties": {
        "envelope_id": {
          "type": "string"
        },
        "envelope_digest": {
          "type": "string"
        }
      }
    },
    "binds_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "decision_digest"
      ],
      "properties": {
        "decision_id": {
          "type": "string"
        },
        "decision_digest": {
          "type": "string"
        }
      }
    },
    "binds_certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certification_id",
        "certification_digest"
      ],
      "properties": {
        "certification_id": {
          "type": "string"
        },
        "certification_digest": {
          "type": "string"
        }
      }
    },
    "entered_indoubt_at": {
      "type": "string",
      "format": "date-time"
    },
    "indoubt_trigger": {
      "type": "string"
    },
    "indoubt_reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "execution_guard_mode": {
      "enum": [
        "OCC",
        "LEASE",
        "SERIALIZABLE_TXN",
        "NONE"
      ]
    },
    "reconciliation_started_at": {
      "type": "string",
      "format": "date-time"
    },
    "reconciliation_actor": {
      "type": "string"
    },
    "reconciliation_mode": {
      "enum": [
        "AUTO",
        "HUMAN_ASSISTED",
        "HUMAN_REQUIRED"
      ]
    },
    "evidence_sources": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "readback_sources": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "reconciliation_attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolution_class",
        "resolution_reason_codes",
        "bounded_uncertainty_flag",
        "human_intervention_flag"
      ],
      "properties": {
        "resolution_class": {
          "enum": [
            "RECONCILED_SUCCESS",
            "RECONCILED_FAILURE",
            "COMPENSATED",
            "UNKNOWN_BOUNDED"
          ]
        },
        "resolution_reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bounded_uncertainty_flag": {
          "type": "boolean"
        },
        "human_intervention_flag": {
          "type": "boolean"
        }
      }
    },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "closed_corridor_state",
        "resulting_result_receipt_ref"
      ],
      "properties": {
        "closed_corridor_state": {
          "enum": [
            "RESULT_OBSERVED",
            "TERMINAL_SUCCESS",
            "TERMINAL_FAILURE",
            "ESCALATED",
            "RESET_REQUIRED"
          ]
        },
        "resulting_result_receipt_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "receipt_id",
            "receipt_digest"
          ],
          "properties": {
            "receipt_id": {
              "type": "string"
            },
            "receipt_digest": {
              "type": "string"
            }
          }
        },
        "compensation_receipt_ref": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    },
    "seal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payload_digest",
        "signature_alg",
        "signed_by",
        "signature"
      ],
      "properties": {
        "payload_digest": {
          "type": "string"
        },
        "signature_alg": {
          "type": "string"
        },
        "signed_by": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        }
      }
    }
  }
}