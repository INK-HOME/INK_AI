{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "promoted-claim.schema.json",
  "title": "PromotedClaim",
  "type": "object",
  "required": [
    "claim_id",
    "source_artifact_id",
    "claim_text_digest",
    "supporting_evidence_ids",
    "promotion_digest"
  ],
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "source_artifact_id": {
      "type": "string"
    },
    "claim_text_digest": {
      "type": "string"
    },
    "supporting_evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "promotion_digest": {
      "type": "string"
    }
  },
  "additionalProperties": false
}