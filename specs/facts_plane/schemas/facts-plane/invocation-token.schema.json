{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://facts-plane.github.io/facts-plane-spec/schemas/facts-plane/invocation-token.schema.json",
  "title": "InvocationToken",
  "type": "object",
  "required": ["payload", "mac"],
  "properties": {
    "payload": {
      "type": "object",
      "required": [
        "ver",
        "tenant_id",
        "trace_id",
        "tool_name",
        "args_digest",
        "expected_side_effects_digest",
        "policy_epoch",
        "expires_at_utc"
      ],
      "properties": {
        "ver": { "type": "string", "minLength": 1 },
        "tenant_id": { "type": "string", "minLength": 1 },
        "trace_id": { "type": "string", "minLength": 1 },
        "tool_name": { "type": "string", "minLength": 1 },
        "args_digest": { "$ref": "common.schema.json#/$defs/DigestString" },
        "expected_side_effects_digest": {
          "anyOf": [
            { "$ref": "common.schema.json#/$defs/DigestString" },
            { "type": "null" }
          ]
        },
        "policy_epoch": { "type": "string", "minLength": 1 },
        "expires_at_utc": { "$ref": "common.schema.json#/$defs/UtcTimestamp" }
      },
      "additionalProperties": false
    },
    "mac": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
